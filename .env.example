# 把这个文件复制成 .env.local 并填上你的 OpenAI API key
# https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-...

# 数据目录，默认 ./data；可以改成绝对路径（比如放到 iCloud/Dropbox 同步文件夹）
# DATA_DIR=/Users/you/Documents/dailynote-data

# ─── 多模型支持（可选）───

# 选择 AI 提供商：openai（默认）| anthropic | openai_compatible
# LLM_PROVIDER=openai

# Anthropic API key（当 llmProvider=anthropic 时使用）
# ANTHROPIC_API_KEY=sk-ant-...

# Anthropic 自定义地址（可选）
# ANTHROPIC_BASE_URL=https://custom.anthropic.com

# 兼容 OpenAI 的接口（如 Ollama/vLLM）
# PROVIDER_API_KEY=sk-
# PROVIDER_BASE_URL=http://localhost:11434/v1

# OpenAI 自定义地址（可选，如 Azure/代理）
# OPENAI_BASE_URL=https://api.openai.com

# HTTPS 代理（可选，Ollama/兼容接口用 Node.js 环境变量）
# HTTPS_PROXY=http://127.0.0.1:1087

# 自定义模型名称（可选，覆盖默认的 gpt-5.4-nano / gpt-5.4-mini）
# MODEL_FAST_OVERRIDE=claude-haiku-4-20250514
# MODEL_SMART_OVERRIDE=claude-sonnet-4-20250514
